# Base URL for the deployed frontend. Used for metadata, manifests, and worker routing.
NEXT_PUBLIC_STUDYFLOW_APP_URL="https://studyflow.example.com"

# Optional absolute URL for the deployed API worker. Leave unset for same-origin `/api` routing.
NEXT_PUBLIC_STUDYFLOW_API_URL="https://api.studyflow.example.com"

# Cloudflare D1 database identifier for worker deployment.
CLOUDFLARE_D1_DATABASE_ID="00000000-0000-0000-0000-000000000000"

# Google OAuth Client Credentials (required for production, optional in sandbox)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

