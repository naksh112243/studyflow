{
  "productName": "StudyFlow",
  "version": "1.0.0",
  "identifier": "com.studyflow.app",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "title": "StudyFlow",
        "width": 1024,
        "height": 768,
        "minWidth": 400,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}