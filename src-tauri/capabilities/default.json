{
  "$schema": "../capabilities-schema.json",
  "identifier": "default",
  "description": "Default capabilities for StudyFlow",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",

    "sql:default",
    "dialog:default",
    "notification:default",
    "fs:default",

    "fs:create-app-specific-dirs",
    "fs:allow-mkdir",

    "fs:allow-appdata-read",
    "fs:allow-appdata-read-recursive",

    "fs:allow-appdata-write",
    "fs:allow-appdata-write-recursive"
  ]
}